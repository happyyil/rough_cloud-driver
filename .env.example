# Vercel Blob Storage Token
# 这个 token 由 Vercel 自动提供，无需手动配置
# 部署到 Vercel 后，系统会自动设置 BLOB_READ_WRITE_TOKEN 环境变量
BLOB_READ_WRITE_TOKEN=

# PIN 码哈希值（SHA256）
# 生成方法：echo -n "你的PIN码" | sha256sum
# 例如：如果 PIN 码是 "123456"，则哈希值为 "8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92"
PIN_HASH=

# Flask Session 密钥
# 用于加密 session，建议使用随机字符串
# 在 Vercel 部署时会自动生成，本地开发可以使用固定值
SECRET_KEY=